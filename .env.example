PORT=5000
MONGO_URI=mongodb://localhost:27017/security_guard_app
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Firebase Admin SDK (for FCM push notifications)
# Download serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./src/config/serviceAccountKey.json

# File upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5

# App base URL (for serving uploaded files)
BASE_URL=http://localhost:5000
